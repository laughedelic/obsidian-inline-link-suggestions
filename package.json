{
	"name": "obsidian-inline-link-suggestions",
	"version": "0.2.1",
	"description": "Inline suggestions for unlinked mentions: underlines plain text matching existing note titles and aliases, click to link.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:e2e": "node esbuild.config.mjs production && wdio run e2e/wdio.conf.mts",
		"test:e2e:mobile": "node esbuild.config.mjs production && OBSIDIAN_E2E_MOBILE=1 wdio run e2e/wdio.mobile-emulation.conf.mts",
		"build:e2e": "tsc -noEmit -skipLibCheck -p e2e",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint ."
	},
	"keywords": [
		"obsidian",
		"obsidian-plugin",
		"links",
		"unlinked-mentions"
	],
	"license": "MIT",
	"devDependencies": {
		"@codemirror/language": "^6.10.0",
		"@codemirror/state": "6.5.0",
		"@codemirror/view": "6.38.6",
		"@eslint/js": "^9.39.4",
		"@types/mocha": "^10.0.10",
		"@types/node": "^22.15.17",
		"@wdio/cli": "^9.29.1",
		"@wdio/globals": "^9.29.1",
		"@wdio/local-runner": "^9.29.1",
		"@wdio/mocha-framework": "^9.29.1",
		"esbuild": "0.25.5",
		"eslint": "^9.39.4",
		"eslint-plugin-obsidianmd": "^0.4.0",
		"globals": "^17.6.0",
		"jiti": "^2.6.1",
		"mocha": "^11.7.6",
		"obsidian": "latest",
		"tsx": "^4.23.1",
		"typescript": "^5.8.3",
		"typescript-eslint": "^8.59.1",
		"vitest": "^3.2.0",
		"wdio-obsidian-reporter": "^3.1.1",
		"wdio-obsidian-service": "^3.1.1"
	}
}
